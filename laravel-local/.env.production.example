# OpenRouter placeholder only. Add the key manually when you are ready to use it.
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_TIMEOUT=30
OPENROUTER_MAX_RETRIES=2

# OpenClaw WhatsApp sender defaults for Linux/VPS.
OPENCLAW_MESSAGING_ENABLED=false
OPENCLAW_SEND_TIMEOUT=45
OPENCLAW_SEND_MAX_ATTEMPTS=2
